on init
    write /sys/kernel/boot_adsp/boot 1
    load_system_props
    class_start core

service logd /system/bin/logd
    class core
    socket logd stream 0666 root root
    socket logdr seqpacket 0666 root root
    socket logdw dgram 0222 root root

service servicemanager /system/bin/servicemanager
    class core

# The modem firmware reaches its EFS/NV data (the modemst1/modemst2/fsg
# partitions) through this daemon over QMI. Without it the modem errfatals
# after an EFS-sync timeout and the subsystem-restart policy resets the
# whole SoC.
service rmt_storage /system/bin/rmt_storage
    class core

service sensors /system/bin/sensors.qcom
    class core
    oneshot

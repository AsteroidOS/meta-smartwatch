From abdcafae813efdc4e7fc20f3c1a8cecc96cd4ecf Mon Sep 17 00:00:00 2001
From: Arseniy Movshev <dodoradio@outlook.com>
Date: Fri, 17 Jul 2026 18:54:21 +0100
Subject: [PATCH] dw_mmc: condition on CONFIG_BCMDHD_SDIO instead of
 CONFIG_BCMDHD

Upstream-Status: Inappropriate
---
 drivers/mmc/host/dw_mmc.c | 6 +++---
 1 file changed, 3 insertions(+), 3 deletions(-)

diff --git a/drivers/mmc/host/dw_mmc.c b/drivers/mmc/host/dw_mmc.c
index 2a6d5500da0d..2a078a1b393a 100644
--- a/drivers/mmc/host/dw_mmc.c
+++ b/drivers/mmc/host/dw_mmc.c
@@ -3485,7 +3485,7 @@ static void dw_mci_work_routine_card(struct work_struct *work)
 	}
 }
 
-#if defined(CONFIG_BCMDHD)
+#if defined(CONFIG_BCMDHD_SDIO)
 static void dw_mci_notify_change(struct platform_device *dev, int state)
 {
     struct dw_mci *host = platform_get_drvdata(dev);
@@ -3556,7 +3556,7 @@ static irqreturn_t dw_mci_detect_interrupt(int irq, void *dev_id)
 	return IRQ_HANDLED;
 }
 
-#if defined(CONFIG_BCMDHD)
+#if defined(CONFIG_BCMDHD_SDIO)
 void (*wifi_status_cb) (struct platform_device *dev, int state);
 struct platform_device *wifi_status_cb_devid;
 int wcf_status_register(void (*cb)(struct platform_device *dev, int state));
@@ -3676,7 +3676,7 @@ static int dw_mci_init_slot(struct dw_mci *host, unsigned int id)
 	/* Card initially undetected */
 	slot->last_detect_state = 0;
 
-#if defined(CONFIG_BCMDHD)
+#if defined(CONFIG_BCMDHD_SDIO)
 	// ONLY FOR Koi/Ayu device's wlan card
 	if (strcmp(to_platform_device(host->dev)->name, "13560000.dwmmc2") == 0)  {
 		if (!host->pdata->ext_cd_init) {
-- 
2.55.0


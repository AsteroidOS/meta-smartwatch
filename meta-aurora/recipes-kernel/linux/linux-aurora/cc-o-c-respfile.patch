Subject: [PATCH] kbuild: C compile via @response-file (qcacld/WiFi)

cmd_cc_o_c = $(CC) $(c_flags) -c -o $@ $< — for qcacld-3.0 $(c_flags)
(huge include+define set) makes the single /bin/sh command exceed the
kernel MAX_ARG_STRLEN (128 KiB per argv) -> E127 before cc runs. Write
$(c_flags) to a clang/gcc @response-file via GNU make builtin $(file
...) (no shell/argv limit). Generic; same technique as cmd_mod.

Upstream-Status: Inappropriate [aurora qcacld out-of-tree workaround]

Signed-off-by: Florent Revest <revestflo@gmail.com>
---
--- a/scripts/Makefile.build
+++ b/scripts/Makefile.build
@@ -156,7 +156,13 @@
 # (See cmd_cc_o_c + relevant part of rule_cc_o_c)
 
 quiet_cmd_cc_o_c = CC $(quiet_modtag)  $@
-      cmd_cc_o_c = $(CC) $(c_flags) -c -o $@ $<
+# qcacld: $(c_flags) is so large that `$(CC) $(c_flags) ...`
+# exceeds the kernel MAX_ARG_STRLEN (128 KiB single argv) ->
+# /bin/sh "Argument list too long" (E127) before cc runs.
+# Pass flags via a clang/gcc @response-file written with GNU
+# make builtin $(file ...) (no shell/argv limit). Generic &
+# harmless for all modules. (aurora qcacld/WiFi.)
+      cmd_cc_o_c = $(file >$@.rsp,$(c_flags)) $(CC) @$@.rsp -c -o $@ $< && rm -f $@.rsp
 
 ifdef CONFIG_MODVERSIONS
 # When module versioning is enabled the following steps are executed:
